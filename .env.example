# SEBS Global — örnek ortam değişkenleri
# Kopyalayın: cp .env.example .env

# --- Zorunlu (production) ---
NODE_ENV=production
JWT_SECRET=
DATABASE_URL=
# veya DB_PASSWORD= (Supabase pooler ile birlikte SUPABASE_PROJECT_REF)
SUPABASE_JWT_SECRET=
# Canlı: https://sebsglobal.com,https://www.sebsglobal.com — Yerel: http://localhost:8006
CORS_ORIGIN=https://sebsglobal.com,https://www.sebsglobal.com
PUBLIC_SITE_URL=https://sebsglobal.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Canlıya alırken (Render / VPS / Docker):
# 1) CORS_ORIGIN = sitenizin tam kök URL’si (virgülle birden fazla: https://a.com,https://www.a.com)
# 2) DATABASE_URL ile SUPABASE_URL aynı Supabase projesine ait olmalı (aksi halde sunucu başlamaz)
# 3) SUPABASE_JWT_SECRET = Dashboard → Project Settings → JWT Secret (JWT ayarları)
# 4) Supabase → Authentication → URL Configuration: Site URL + Redirect URLs’e https://alanadiniz/auth/callback.html ekleyin
# 5) PUBLIC_SITE_URL = tek kanonik site adresi (log ve yönlendirmeler için)

# --- Supabase DB (DATABASE_URL yoksa; DB_PASSWORD ile birlikte zorunlu) ---
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_POOLER=aws-1-eu-central-1.pooler.supabase.com
# DB_PASSWORD=
# DB_POOL_MAX=5
# DB_POOL_MIN=1

# --- Opsiyonel ---
PORT=8006
TRUST_PROXY=1
SUPER_ADMIN_EMAIL=
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# --- E-posta ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# İletişim formu mesajlarının gideceği adres (SMTP ile gönderilir; varsayılan sebsglobal@gmail.com)
CONTACT_INBOX_EMAIL=sebsglobal@gmail.com
# İsteğe bağlı: iletişim formu IP limiti (15 dk içinde)
# RATE_LIMIT_CONTACT_MAX=5

# --- Yerel PostgreSQL (Supabase kullanılmıyorsa) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=sebs_education
# DB_USER=postgres
