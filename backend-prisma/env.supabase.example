# ============================================
# SEBS Backend - Supabase Auth Environment
# ============================================

# Supabase Configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database (Supabase PostgreSQL)
# DATABASE_URL → Pooler (uygulama trafiği, serverless uyumlu) - Port 6543
# DIRECT_URL → Direct (migrations, pg_dump) - Port 5432
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Server Configuration
PORT=8006
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.com

# Payment Webhooks
# Iyzico
IYZICO_WEBHOOK_SECRET=your-iyzico-webhook-secret

# Stripe (optional)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ============================================
# NOTES:
# ============================================
# 1. SUPABASE_SERVICE_ROLE_KEY: 
#    - NEVER expose to frontend
#    - Only use in backend for admin operations
#    - Found in: Supabase Dashboard → Settings → API
#
# 2. SUPABASE_ANON_KEY:
#    - Safe to expose to frontend
#    - Used for JWT verification in backend
#    - Found in: Supabase Dashboard → Settings → API
#
# 3. DATABASE_URL (Pooler - Transaction mode):
#    - Prisma runtime için - Settings → Database → Connection pooling → Transaction
#    - Port 6543, pooler.supabase.com
#
# 4. DIRECT_URL (Direct):
#    - Migrations için - Settings → Database → Connection string → URI
#    - Port 5432, db.[PROJECT-REF].supabase.co
