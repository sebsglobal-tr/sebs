// Prisma Schema - Supabase Auth Version
// Auth is handled by Supabase, this schema only contains domain models

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Profile Model - Links to auth.users
// Note: id matches auth.users.id
model Profile {
  id          String   @id // UUID from auth.users
  fullName    String?  @map("full_name")
  phone       String?
  role        String   @default("user") // user, admin, instructor
  accessLevel String   @default("beginner") @map("access_level") // beginner, intermediate, advanced
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  purchases         Purchase[]
  entitlements      Entitlement[]
  progress          Progress[]
  simulationRuns    SimulationRun[]
  certificates      Certificate[]
  moduleProgress    ModuleProgress[]
  quizAttempts      QuizAttempt[]
  loginLogs         UserLoginLog[]
  moduleSessions    UserModuleSession[]

  @@map("profiles")
}

// Package Model
model Package {
  id          String    @id @default(uuid())
  name        String
  description String?
  category    String // cybersecurity, cloud, datascience
  level       String // beginner, intermediate, advanced
  price       Decimal   @db.Decimal(10, 2)
  durationDays Int?      @map("duration_days") // null = lifetime
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  purchases Purchase[]

  @@map("packages")
}

// Purchase Model
model Purchase {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  packageId     String    @map("package_id")
  transactionId String?   @map("transaction_id")
  amount        Decimal   @db.Decimal(10, 2)
  status        String    @default("pending") // pending, completed, failed, refunded
  purchasedAt   DateTime  @default(now()) @map("purchased_at")
  expiresAt     DateTime? @map("expires_at")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id], onDelete: Restrict)
  entitlement Entitlement?

  @@index([userId])
  @@index([status])
  @@index([transactionId])
  @@map("purchases")
}

// Entitlement Model
model Entitlement {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  category    String
  level       String
  purchasedAt DateTime  @default(now()) @map("purchased_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean   @default(true) @map("is_active")
  purchaseId  String?   @unique @map("purchase_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user    Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchase Purchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)

  @@unique([userId, category, level])
  @@index([userId])
  @@index([category, level])
  @@index([isActive])
  @@map("entitlements")
}

// Course Model
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  level       String
  thumbnail   String?
  isPublished Boolean  @default(false) @map("is_published")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lessons Lesson[]
  modules Module[]

  @@index([category, level])
  @@index([isPublished])
  @@map("courses")
}

// Module Model - modül kataloğu (course veya bağımsız)
model Module {
  id          String   @id @default(uuid())
  courseId    String?  @map("course_id")
  title       String
  description String?
  category    String?
  level       String?
  order       Int      @default(0) @map("sort_order")
  type        String?  @default("lesson")
  duration    Int?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course           Course?             @relation(fields: [courseId], references: [id], onDelete: SetNull)
  progress         ModuleProgress[]
  quizAttempts     QuizAttempt[]
  moduleSessions   UserModuleSession[]

  @@index([courseId])
  @@index([isActive])
  @@map("modules")
}

// ModuleProgress - kullanıcı modül ilerlemesi (Dashboard)
model ModuleProgress {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  moduleId         String    @map("module_id")
  percentComplete  Int       @default(0) @map("percent_complete")
  isCompleted      Boolean   @default(false) @map("is_completed")
  timeSpentMinutes Int       @default(0) @map("time_spent_minutes")
  lastStep         String?   @map("last_step")
  lastAccessedAt   DateTime  @default(now()) @map("last_accessed_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId])
  @@index([moduleId])
  @@index([isCompleted])
  @@map("module_progress")
}

// Lesson Model
model Lesson {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  description String?
  content     String?
  order       Int      @default(0)
  type        String   @default("lesson") // lesson, lab, quiz, exam
  duration    Int? // minutes
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course         Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress       Progress[]
  simulationRuns SimulationRun[]
  simulations    Simulation[]

  @@index([courseId])
  @@index([type])
  @@map("lessons")
}

// Simulation Model
model Simulation {
  id           String   @id @default(uuid())
  lessonId     String?  @map("lesson_id")
  simulationId String   @unique // e.g., "cafe-hack"
  title        String
  description  String?
  category     String?
  level        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  lesson       Lesson?        @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  simulationRuns SimulationRun[]

  @@index([lessonId])
  @@index([category, level])
  @@map("simulations")
}

// Progress Model
model Progress {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  lessonId        String    @map("lesson_id")
  percentComplete Int       @default(0) @map("percent_complete")
  isCompleted     Boolean   @default(false) @map("is_completed")
  timeSpentMinutes Int      @default(0) @map("time_spent_minutes")
  lastStep        String?   @map("last_step")
  lastAccessedAt  DateTime  @default(now()) @map("last_accessed_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([isCompleted])
  @@map("progress")
}

// SimulationRun Model
model SimulationRun {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  lessonId       String?   @map("lesson_id")
  simulationId   String    @map("simulation_id")
  score          Int?
  flagsFound     String[]  @map("flags_found")
  timeSpent      Int       @default(0) @map("time_spent")
  attempts       Int       @default(0)
  completionTime Int?      @map("completion_time")
  decisionCount  Int       @default(0) @map("decision_count")
  errorCount     Int       @default(0) @map("error_count")
  successRate    Decimal?  @db.Decimal(5, 2) @map("success_rate")
  startedAt      DateTime? @map("started_at")
  correctCount   Int       @default(0) @map("correct_count")
  wrongCount     Int       @default(0) @map("wrong_count")
  passed         Boolean?  @map("passed")
  maxScore       Int?      @map("max_score")
  wrongActionsCount Int    @default(0) @map("wrong_actions_count")
  hintUsedCount  Int       @default(0) @map("hint_used_count")
  resetCount     Int       @default(0) @map("reset_count")
  stepCompletionTimes Json? @map("step_completion_times")
  finalGradeLabel String? @map("final_grade_label")
  completedAt    DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  user       Profile     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  simulation Simulation? @relation(fields: [simulationId], references: [simulationId], onDelete: SetNull)

  @@index([userId])
  @@index([simulationId])
  @@map("simulation_runs")
}

// QuizAttempt - Test/Değerlendirme sonuçları (kaç doğru, kaç yanlış)
model QuizAttempt {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  moduleId        String   @map("module_id")
  quizSectionId   String   @map("quiz_section_id") // e.g. "değerlendirme-testi-10-soru"
  totalQuestions  Int      @map("total_questions")
  correctCount    Int      @map("correct_count")
  wrongCount      Int      @map("wrong_count")
  scorePercent    Int?     @map("score_percent")
  attemptedAt     DateTime @default(now()) @map("attempted_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([moduleId])
  @@index([attemptedAt])
  @@map("quiz_attempts")
}

// UserLoginLog - Günlük giriş takibi (her gün girip girmediği)
model UserLoginLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  loggedAt  DateTime @default(now()) @map("logged_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([loggedAt])
  @@map("user_login_logs")
}

// UserModuleSession - Günlük modül süresi (girdiğinde modülde ne kadar süre geçirdi)
model UserModuleSession {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  moduleId       String   @map("module_id")
  sessionDate    DateTime @map("session_date") // Tarih (gün bazlı)
  minutesSpent   Int      @default(0) @map("minutes_spent")
  lastUpdatedAt  DateTime @default(now()) @updatedAt @map("last_updated_at")

  user   Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  @@unique([userId, moduleId, sessionDate])
  @@index([userId])
  @@index([sessionDate])
  @@map("user_module_sessions")
}

// Certificate Model
model Certificate {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  category       String
  title          String
  description    String?
  completionTime Int      @map("completion_time")
  earnedAt       DateTime @default(now()) @map("earned_at")
  certificateUrl String? @map("certificate_url")
  metadata       Json?

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@map("certificates")
}
