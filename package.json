{
  "name": "sebs-global",
  "private": true,
  "version": "1.0.0",
  "description": "SEBS Global — monorepo: frontend (statik), backend (Express API), database (SQL)",
  "scripts": {
    "start": "npm --prefix backend start",
    "dev": "npm --prefix backend run dev",
    "start:alt": "PORT=8010 npm --prefix backend start",
    "restart": "./scripts/restart-local.sh",
    "start:cluster": "npm --prefix backend run start:cluster",
    "build": "node scripts/verify-build.js",
    "setup-db": "node setup-database-tables.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "dotenv": "^16.6.1",
    "pg": "^8.16.3"
  }
}
