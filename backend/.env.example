# Backend API — örnek ortam değişkenleri (kopyalayın: cp .env.example .env)

NODE_ENV=development
PORT=8006

DATABASE_URL=postgresql://user:pass@host:5432/postgres

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=change-me-in-production

# Geliştirmede ücretsiz /api/purchase (prod'da Iyzico zorunlu)
ALLOW_DEV_PURCHASE=0
DISABLE_DIRECT_PURCHASE=1

# Iyzico Checkout Form (sandbox anahtarları yalnızca backend'de — asla frontend'e koymayın)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Opsiyonel: eksik profil alanları için sandbox varsayılanları
IYZICO_DEFAULT_GSM=5555555555
IYZICO_DEFAULT_IDENTITY=11111111111
IYZICO_DEFAULT_ADDRESS=Istanbul Turkiye
IYZICO_DEFAULT_CITY=Istanbul
IYZICO_DEFAULT_ZIP=34000
# Ödeme sonrası yönlendirme (Vercel frontend)
FRONTEND_URL=http://localhost:3000
# Render backend public URL (callback + webhook)
BACKEND_URL=
API_PUBLIC_URL=http://localhost:8006
# Iyzico panelinde tanımlı callback (boşsa BACKEND_URL veya API_PUBLIC_URL + /api/payments/iyzico/callback)
IYZICO_CALLBACK_URL=
# Webhook URL (iyzico panel): BACKEND_URL/api/payments/iyzico/webhook

# iyzico Abonelik (SEBS Yolu aylık planlar)
IYZICO_SUBSCRIPTION_ENABLED=1
IYZICO_SUBSCRIPTION_PRODUCT_REF=216d9563-f6a4-4300-972d-34af5162fc30
IYZICO_PLAN_ILK_ADIM=dc2edf07-5cba-40ea-97c3-ba82c8a6c20c
IYZICO_PLAN_YUKSELIS=1e9caf79-c742-4d10-a142-83cdf9f8d163
IYZICO_PLAN_ZIRVE=47530f5e-0bbf-418a-990a-97f2cfe1eb7e
# Abonelik callback (boşsa BACKEND_URL/api/payments/iyzico/subscription/callback)
IYZICO_SUBSCRIPTION_CALLBACK_URL=
# Erişim süresi (gün) — iyzico dönem sonu alınamazsa yedek
SUBSCRIPTION_PERIOD_DAYS=30
