# Backend API — örnek ortam değişkenleri (kopyalayın: cp .env.example .env)

NODE_ENV=development
PORT=8006

DATABASE_URL=postgresql://user:pass@host:5432/postgres

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

JWT_SECRET=change-me-in-production

# Geliştirmede ücretsiz /purchase (prod'da kapalı)
ALLOW_FREE_PURCHASE=false

# Iyzico Checkout Form (sandbox)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Opsiyonel: varsayılanlar sandbox test alıcısı için
IYZICO_DEFAULT_GSM=5555555555
IYZICO_DEFAULT_IDENTITY=11111111111
IYZICO_DEFAULT_ADDRESS=Istanbul Turkiye
IYZICO_DEFAULT_CITY=Istanbul
IYZICO_DEFAULT_ZIP=34000
# Ödeme sonrası yönlendirme tabanı
FRONTEND_URL=http://localhost:3000
API_PUBLIC_URL=http://localhost:8006
# Iyzico panelinde tanımlı callback (boşsa API_PUBLIC_URL + /api/payments/iyzico/callback)
IYZICO_CALLBACK_URL=
