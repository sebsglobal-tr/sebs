// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User Model with ULID publicId
model User {
  id                      String    @id @default(uuid())
  publicId                String    @unique @default(uuid()) // ULID will be generated manually
  email                   String    @unique
  passwordHash            String    @map("password_hash")
  firstName               String?   @map("first_name")
  lastName                String?   @map("last_name")
  phone                   String?
  isVerified              Boolean   @default(false) @map("is_verified")
  isActive                Boolean   @default(true) @map("is_active")
  role                    String    @default("user") // user, admin, instructor
  accessLevel             String    @default("beginner") @map("access_level") // beginner, intermediate, advanced - satın alınan seviye
  lastLogin               DateTime? @map("last_login")
  verificationCode        String?   @map("verification_code")
  verificationCodeExpires DateTime? @map("verification_code_expires")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  enrollments       Enrollment[]
  moduleProgress    ModuleProgress[]
  simulationRuns    SimulationRun[]
  refreshTokens     RefreshToken[]
  certificates      Certificate[]
  entitlements      Entitlement[]
  behaviorData      BehaviorData[]
  skillScores       SkillScore[]
  aiAnalyses        AIAnalysis[]
  securityLogsAdmin SecurityLog[]    @relation("AdminLogs")

  @@map("users")
}

// Course Model (Static/Seeded)
model Course {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String // cybersecurity, cloud, datascience, etc.
  level       String   @default("beginner") // beginner, intermediate, advanced
  thumbnail   String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  modules     Module[]
  enrollments Enrollment[]

  @@map("courses")
}

// Module Model (Static/Seeded, Belongs to Course)
model Module {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  description String?
  content     String? // JSON or HTML content
  order       Int      @default(0)
  type        String   @default("lesson") // lesson, lab, quiz, exam
  duration    Int? // minutes
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress       ModuleProgress[]
  simulationRuns SimulationRun[]

  @@map("modules")
}

// Enrollment (User enrolled in Course)
model Enrollment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  courseId    String    @map("course_id")
  enrolledAt  DateTime  @default(now()) @map("enrolled_at")
  completedAt DateTime? @map("completed_at")
  isActive    Boolean   @default(true) @map("is_active")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@map("enrollments")
}

// Module Progress (User progress in specific Module)
model ModuleProgress {
  id               String    @id @default(uuid())
  userId           String    @map("user_id")
  moduleId         String    @map("module_id")
  percentComplete  Int       @default(0) @map("percent_complete")
  lastStep         String?   @map("last_step")
  isCompleted      Boolean   @default(false) @map("is_completed")
  timeSpentMinutes Int       @default(0) @map("time_spent_minutes")
  lastAccessedAt   DateTime  @default(now()) @map("last_accessed_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@map("module_progress")
}

// Simulation Run (User simulation results)
model SimulationRun {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  moduleId       String    @map("module_id")
  simulationId   String    @map("simulation_id") // e.g., "cafe-hack", "network-security"
  score          Int?
  flagsFound     String[]  @map("flags_found")
  timeSpent      Int       @default(0) @map("time_spent") // seconds
  attempts       Int       @default(0)
  completionTime Int?      @map("completion_time") // total completion time in seconds
  decisionCount  Int       @default(0) @map("decision_count")
  errorCount     Int       @default(0) @map("error_count")
  successRate    Float?    @map("success_rate") // 0-1
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@map("simulation_runs")
}

// Refresh Token for JWT auth
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// Certificate model
model Certificate {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  category       String // siber-guvenlik, bulut-bilisim, veri-bilimi, teknoloji
  title          String // "Temel Siber Güvenlik", "Network Güvenliği", etc.
  description    String?
  completionTime Int      @map("completion_time") // minutes
  earnedAt       DateTime @default(now()) @map("earned_at")
  certificateUrl String?  @map("certificate_url") // PDF URL
  metadata       String? // JSON: { modules: [], simulations: [], errors: [], avgScore: 0 }

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

// Entitlement (User's purchased package access)
model Entitlement {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  category      String // cybersecurity, cloud, datascience, etc.
  level         String // beginner, intermediate, advanced
  purchasedAt   DateTime  @default(now()) @map("purchased_at")
  expiresAt     DateTime? @map("expires_at") // null means lifetime access
  isActive      Boolean   @default(true) @map("is_active")
  transactionId String?   @map("transaction_id") // payment transaction ID
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, level])
  @@map("entitlements")
}

// Behavior Data (User behavior patterns)
model BehaviorData {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  simulationRunId      String?  @map("simulation_run_id")
  decisionLatency      Int?     @map("decision_latency") // milliseconds
  retryRate            Float?   @map("retry_rate") // 0-1
  errorPattern         String?  @map("error_pattern") // JSON: { type: "timing", frequency: 3 }
  stressIndicator      Float?   @map("stress_indicator") // 0-1
  deviationScore       Float?   @map("deviation_score") // 0-1
  timePressureResponse Float?   @map("time_pressure_response") // 0-1
  sequenceDeviation    Float?   @map("sequence_deviation") // 0-1
  metadata             String? // JSON: additional behavioral data
  createdAt            DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("behavior_data")
}

// Skill Scores (User competency tracking)
model SkillScore {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  skillName   String   @map("skill_name") // "Network Security", "OS Security", "Malware Analysis", "Cloud Security"
  score       Float // 0-100
  confidence  String   @default("medium") // low, medium, high
  stability   String   @default("stable") // stable, improving, declining, unstable
  trend       Float? // -1 to 1 (improvement rate)
  lastUpdated DateTime @default(now()) @map("last_updated")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillName])
  @@index([userId])
  @@index([skillName])
  @@map("skill_scores")
}

// AI Analysis (AI-generated insights and recommendations)
model AIAnalysis {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  insightText    String   @map("insight_text") // "Bu kullanıcı teknik olarak iyi fakat baskı altında karar kalitesi düşüyor."
  recommendation String? // "İleri seviye Cloud simülasyonu önerilir."
  riskLevel      String   @default("low") @map("risk_level") // low, medium, high
  category       String? // "performance", "behavior", "skill", "recommendation"
  metadata       String? // JSON: additional analysis data
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([riskLevel])
  @@index([createdAt])
  @@map("ai_analysis")
}

// Security Logs (Admin actions and security events)
model SecurityLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id") // nullable for system logs
  userId     String?  @map("user_id") // nullable for admin actions
  action     String // "login", "data_access", "user_update", "permission_change", "anomaly_detected"
  resource   String? // "user", "simulation", "data"
  resourceId String?  @map("resource_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  success    Boolean  @default(true)
  details    String? // JSON: additional log details
  createdAt  DateTime @default(now()) @map("created_at")

  admin User? @relation("AdminLogs", fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("security_logs")
}
