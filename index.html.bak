    <!-- JavaScript -->
    <script>
        // ============================================
        // YÜKLEME EKRANI YÖNETİMİ
        // ============================================
        // Sayfa yüklendiğinde yükleme ekranını gizler
        let loadingHidden = false; // Çift gizleme önleme bayrağı
        
        function hideLoadingScreen() {
            // Zaten gizlenmişse tekrar gizlemeye çalışma
            if (loadingHidden) return;
            
            const loadingOverlay = document.getElementById('loadingOverlay');
            if (loadingOverlay && !loadingOverlay.classList.contains('hidden')) {
                loadingHidden = true; // Bayrağı set et
                
                // Fade out animasyonu ile gizle
                loadingOverlay.classList.add('hidden');
                
                // Animasyon tamamlandıktan sonra DOM'dan kaldır
                setTimeout(() => {
                    loadingOverlay.style.display = 'none';
                    console.log('✅ Yükleme ekranı gizlendi');
                }, 500); // CSS transition süresi ile eşleşmeli
            }
        }

        // Global olarak erişilebilir yap (debug için)
        window.hideLoadingScreen = hideLoadingScreen;

        // Yükleme ekranını gizlemek için çoklu yöntem kullan
        // 1. DOMContentLoaded (DOM hazır olduğunda)
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', function() {
                console.log('📄 DOM hazır - yükleme ekranı 1 saniye sonra gizlenecek');
                setTimeout(hideLoadingScreen, 1000);
            });
        } else {
            // DOM zaten yüklenmişse hemen başlat
            console.log('📄 DOM zaten hazır - yükleme ekranı 0.5 saniye sonra gizlenecek');
            setTimeout(hideLoadingScreen, 500);
        }

        // 2. Window load (tüm kaynaklar yüklendiğinde)
        window.addEventListener('load', function() {
            console.log('🖼️ Tüm kaynaklar yüklendi - yükleme ekranı 0.3 saniye sonra gizlenecek');
            setTimeout(hideLoadingScreen, 300);
        });

        // 3. Güvenlik: 2 saniye sonra kesinlikle gizle (hata durumunda takılmasın)
        setTimeout(function() {
            if (!loadingHidden) {
                console.warn('⚠️ Yükleme ekranı 2 saniye sonra zorla gizleniyor (timeout)');
                hideLoadingScreen();
            }
        }, 2000);

        // 4. Çift güvenlik: 3 saniye sonra kesinlikle gizle
        setTimeout(function() {
            const loadingOverlay = document.getElementById('loadingOverlay');
            if (loadingOverlay && loadingOverlay.style.display !== 'none') {
                console.warn('⚠️ Yükleme ekranı 3 saniye sonra zorla gizlendi (final timeout)');
                loadingOverlay.style.display = 'none';
                loadingOverlay.classList.add('hidden');
                loadingHidden = true;
            }
        }, 3000);

        // Access Control Functions
        function checkAccess() {
            const isLoggedIn = localStorage.getItem('isLoggedIn');
            const isVerified = localStorage.getItem('isVerified');
            
            if (!isLoggedIn || !isVerified) {
                return false;
            }
            return true;
        }

        function redirectToModules(event, category = null) {
            event.preventDefault();
            
            if (!checkAccess()) {
                // Show access required message
                showAccessRequiredModal();
                return;
            }
            
            // If access is granted, redirect to modules
            if (category) {
                window.location.href = `modules.html?category=${category}`;
            } else {
                window.location.href = 'modules.html';
            }
        }

        function showAccessRequiredModal() {
            // Create modal overlay
            const modal = document.createElement('div');
            modal.style.cssText = `
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.8);
                display: flex;
                justify-content: center;
                align-items: center;
                z-index: 10000;
                backdrop-filter: blur(10px);
            `;

            // Create modal content
            const modalContent = document.createElement('div');
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            modalContent.style.cssText = `
                background: ${isDark ? '#1e293b' : '#ffffff'};
                padding: 40px;
                border-radius: 20px;
                text-align: center;
                color: ${isDark ? '#f1f5f9' : '#2d3748'};
                max-width: 500px;
                margin: 20px;
                box-shadow: ${isDark ? '0 25px 50px rgba(0, 0, 0, 0.6)' : '0 25px 50px rgba(0, 0, 0, 0.3)'};
                border: ${isDark ? '1px solid rgba(255, 255, 255, 0.08)' : 'none'};
            `;

            modalContent.innerHTML = `
                <div style="font-size: 3rem; margin-bottom: 20px;">🔒</div>
                <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.8rem; margin-bottom: 15px; ${isDark ? 'color: #f1f5f9;' : 'color: #1e293b;'}">Erişim Gerekli</h2>
                <p style="${isDark ? 'color: #cbd5e0;' : 'color: #64748b;'} margin-bottom: 30px; line-height: 1.6;">Eğitim modüllerine erişmek için üye olmanız ve e-posta doğrulaması yapmanız gerekmektedir.</p>
                <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                    <a href="signup.html" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-weight: 600; transition: all 0.3s ease;">Üye Ol</a>
                    <a href="login.html" style="background: ${isDark ? 'rgba(99, 102, 241, 0.1)' : 'rgba(102, 126, 234, 0.1)'}; color: ${isDark ? '#818cf8' : '#667eea'}; padding: 12px 24px; border-radius: 10px; text-decoration: none; font-weight: 600; border: 2px solid ${isDark ? '#818cf8' : '#667eea'}; transition: all 0.3s ease;">Giriş Yap</a>
                </div>
                <button onclick="this.closest('.modal-overlay').remove()" style="background: none; border: none; ${isDark ? 'color: #cbd5e0;' : 'color: #64748b;'} margin-top: 20px; cursor: pointer; font-size: 0.9rem;">Kapat</button>
            `;

            modal.className = 'modal-overlay';
            modal.appendChild(modalContent);
            document.body.appendChild(modal);

            // Close modal when clicking outside
            modal.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.remove();
                }
            });
        }

        // Mobile menu toggle
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');

        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navMenu.classList.toggle('active');
        });

        // Close mobile menu when clicking on a link
        document.querySelectorAll('.nav-link').forEach(n => n.addEventListener('click', () => {
            hamburger.classList.remove('active');
            navMenu.classList.remove('active');
        }));

        // Animated counter for stats
        function animateCounter(element, target, duration = 2000) {
            let start = 0;
            const increment = target / (duration / 16);
            
            function updateCounter() {
                start += increment;
                if (start < target) {
                    element.textContent = Math.floor(start);
                    requestAnimationFrame(updateCounter);
                } else {
                    element.textContent = target;
                }
            }
            
            updateCounter();
        }

        // Intersection Observer for stats animation
        const observerOptions = {
            threshold: 0.5,
            rootMargin: '0px 0px -100px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const statNumbers = entry.target.querySelectorAll('.stat-number');
                    statNumbers.forEach(stat => {
                        const target = parseInt(stat.getAttribute('data-target'));
                        animateCounter(stat, target);
                    });
                    observer.unobserve(entry.target);
                }
            });
        }, observerOptions);

        // Observe stats section
        const statsSection = document.querySelector('.stats');
        if (statsSection) {
            observer.observe(statsSection);
        }

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });

        // Check authentication status
        function checkAuthStatus() {
            const isLoggedIn = localStorage.getItem('isLoggedIn');
            const isVerified = localStorage.getItem('isVerified');
            const userData = JSON.parse(localStorage.getItem('userData') || '{}');
            
            // Find the modules and simulations links
            const modulesLink = document.querySelector('a[onclick="redirectToModules(event)"]');
            const simulationsLink = document.querySelector('a[href="simulations.html"]');
            
            if (isLoggedIn === 'true' && isVerified === 'true') {
                // User is logged in
                document.getElementById('loginBtn').style.display = 'none';
                document.getElementById('signupBtn').style.display = 'none';
                document.getElementById('userProfile').style.display = 'flex';
                document.getElementById('logoutBtn').style.display = 'block';
                
                // Show modules link for logged in users
                if (modulesLink) {
                    modulesLink.parentElement.style.display = 'block';
                }
                
                // Show simulations link for logged in users
                if (simulationsLink) {
                    simulationsLink.parentElement.style.display = 'block';
                }
                
                // Update user info
                const userName = userData.name || userData.firstName || 'Kullanıcı';
                document.getElementById('userName').textContent = userName;
                document.getElementById('userAvatar').textContent = userName.charAt(0).toUpperCase();
                
                // Make user profile clickable to go to dashboard
                document.getElementById('userProfile').onclick = function() {
                    window.location.href = 'dashboard.html';
                };
            } else {
                // User is not logged in
                document.getElementById('loginBtn').style.display = 'block';
                document.getElementById('signupBtn').style.display = 'block';
                document.getElementById('userProfile').style.display = 'none';
                document.getElementById('logoutBtn').style.display = 'none';
                
                // Hide modules link for non-logged in users
                if (modulesLink) {
                    modulesLink.parentElement.style.display = 'none';
                }
                
                // Hide simulations link for non-logged in users
                if (simulationsLink) {
                    simulationsLink.parentElement.style.display = 'none';
                }
            }
        }

        // Logout function
        function logout() {
            if (confirm('Çıkış yapmak istediğinizden emin misiniz?')) {
                localStorage.removeItem('isLoggedIn');
                localStorage.removeItem('isVerified');
                localStorage.removeItem('userData');
                localStorage.removeItem('userProgress');
                localStorage.removeItem('recentActivities');
                localStorage.removeItem('achievements');
                window.location.reload();
            }
        }

        // Update logo based on theme
        function updateLogo() {
            const navLogoImg = document.querySelector('.nav-logo-img');
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme') || 'light';
            
            if (navLogoImg) {
                if (currentTheme === 'dark') {
                    navLogoImg.src = '/images/SEBS.png';
                } else {
                    navLogoImg.src = '/images/SEBS.png';
                }
            }
        }

        // Dark Mode Toggle
        function initDarkMode() {
            const darkModeToggle = document.getElementById('darkModeToggle');
            const darkModeIcon = document.getElementById('darkModeIcon');
            const html = document.documentElement;
            
            // Check saved theme or default to light mode
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                html.setAttribute('data-theme', 'dark');
                if (darkModeIcon) darkModeIcon.className = 'fas fa-sun';
            }
            
            // Update logo on page load
            updateLogo();
            
            if (darkModeToggle) {
                darkModeToggle.addEventListener('click', function() {
                    const currentTheme = html.getAttribute('data-theme');
                    if (currentTheme === 'dark') {
                        html.setAttribute('data-theme', 'light');
                        localStorage.setItem('theme', 'light');
                        if (darkModeIcon) darkModeIcon.className = 'fas fa-moon';
                    } else {
                        html.setAttribute('data-theme', 'dark');
                        localStorage.setItem('theme', 'dark');
                        if (darkModeIcon) darkModeIcon.className = 'fas fa-sun';
                    }
                    // Update logo when theme changes
                    updateLogo();
                });
            }
        }

        // Apply dark mode styles to all elements
        function applyDarkModeStyles() {
            const style = document.createElement('style');
            style.id = 'dark-mode-styles';
            style.textContent = `
                /* Global dark mode - force all backgrounds to dark */
                [data-theme="dark"] {
                    background-color: var(--bg-primary) !important;
                    color: var(--text-primary) !important;
                }
                
                /* Force all sections, containers, and divs to dark (except cards) */
                [data-theme="dark"] body,
                [data-theme="dark"] html,
                [data-theme="dark"] main,
                [data-theme="dark"] .container,
                [data-theme="dark"] .hero-section,
                [data-theme="dark"] .section,
                [data-theme="dark"] .education-areas,
                [data-theme="dark"] .features,
                [data-theme="dark"] .stats,
                [data-theme="dark"] .why-section,
                [data-theme="dark"] .cta-section,
                [data-theme="dark"] .simulations-preview,
                [data-theme="dark"] section,
                [data-theme="dark"] .section-header,
                [data-theme="dark"] .section-title,
                [data-theme="dark"] .section-subtitle,
                [data-theme="dark"] .simulations-grid,
                [data-theme="dark"] .features-grid,
                [data-theme="dark"] .category-tabs,
                [data-theme="dark"] .stats-grid,
                [data-theme="dark"] .hero-content,
                [data-theme="dark"] .floating-elements,
                [data-theme="dark"] div:not(.feature-card):not(.card):not(.module-card):not(.category-card):not(.stats-card):not(.benefit-card):not(.testimonial-card):not(.tab-btn):not(.simulation-card):not(.btn-login):not(.btn-logout):not(.btn-primary):not(.btn-signup):not(.btn-secondary) {
                    background-color: var(--bg-primary) !important;
                    color: var(--text-primary) !important;
                }
                
                /* Cards - modern dark card style */
                [data-theme="dark"] .feature-card,
                [data-theme="dark"] .card,
                [data-theme="dark"] .module-card,
                [data-theme="dark"] .category-card,
                [data-theme="dark"] .stats-card,
                [data-theme="dark"] .benefit-card,
                [data-theme="dark"] .testimonial-card,
                [data-theme="dark"] .tab-btn:not(.active),
                [data-theme="dark"] .simulation-card {
                    background-color: var(--card-bg) !important;
                    border-color: var(--border-color) !important;
                    color: var(--text-primary) !important;
                }
                
                /* Card hover states */
                [data-theme="dark"] .feature-card:hover,
                [data-theme="dark"] .card:hover,
                [data-theme="dark"] .simulation-card:hover {
                    background-color: var(--card-hover) !important;
                }
                
                /* Buttons */
                [data-theme="dark"] .btn-primary,
                [data-theme="dark"] .btn-secondary {
                    color: var(--text-primary);
                }
                
                /* Override any inline white backgrounds */
                [data-theme="dark"] *[style*="background: white"],
                [data-theme="dark"] *[style*="background:#fff"],
                [data-theme="dark"] *[style*="background: #ffffff"],
                [data-theme="dark"] *[style*="background-color: white"],
                [data-theme="dark"] *[style*="background-color:#fff"],
                [data-theme="dark"] *[style*="background-color: #ffffff"],
                [data-theme="dark"] *[style*="background: rgba(255,255,255"],
                [data-theme="dark"] *[style*="background-color: rgba(255,255,255"] {
                    background-color: var(--bg-primary) !important;
                    background: var(--bg-primary) !important;
                }
                
                /* Hide all white pattern overlays */
                [data-theme="dark"] .hero-section::before,
                [data-theme="dark"] .features::before,
                [data-theme="dark"] .stats::before,
                [data-theme="dark"] .cta-section::before {
                    display: none !important;
                }
                
                /* Stats section */
                [data-theme="dark"] .stats {
                    color: var(--text-primary) !important;
                }
                
                [data-theme="dark"] .stat-label {
                    color: var(--text-secondary) !important;
                }
                
                /* Remove white text colors */
                [data-theme="dark"] *[style*="color: white"],
                [data-theme="dark"] *[style*="color:#fff"],
                [data-theme="dark"] *[style*="color: #ffffff"],
                [data-theme="dark"] *[style*="color: rgba(255,255,255"] {
                    color: var(--text-primary) !important;
                }
                
                /* Text colors in dark mode */
                [data-theme="dark"] p,
                [data-theme="dark"] span:not(.sebs):not(.global),
                [data-theme="dark"] .section-subtitle,
                [data-theme="dark"] .hero-subtitle {
                    color: var(--text-secondary) !important;
                }
                
                [data-theme="dark"] h1,
                [data-theme="dark"] h2,
                [data-theme="dark"] h3,
                [data-theme="dark"] h4,
                [data-theme="dark"] h5,
                [data-theme="dark"] h6,
                [data-theme="dark"] .section-title {
                    color: var(--text-primary) !important;
                }
            `;
            // Remove old style if exists
            const oldStyle = document.getElementById('dark-mode-styles');
            if (oldStyle) oldStyle.remove();
            document.head.appendChild(style);
        }

        // Initialize auth status when page loads
        document.addEventListener('DOMContentLoaded', function() {
            checkAuthStatus();
            initDarkMode();
            applyDarkModeStyles();
        });
    </script>
    <!-- Navigation Script -->
    <!-- Supabase Client -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.39.0/dist/umd/supabase.min.js"></script>
    <script src="/js/supabase-client.js"></script>
    <script src="/js/supabase-auth.js"></script>
    <script src="js/navigation.js?v=2.0"></script>
    <!-- Animations -->
    <script src="/js/animations.js"></script>
</body>
</html>