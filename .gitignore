# SEBS Global - .gitignore

# Python (eski backend - artık kullanılmıyor)
*.py
__pycache__/
venv/
*.pyc
*.pyo
*.pyd
.Python

# SQLite Veritabanları (PostgreSQL kullanılıyor)
*.db
*.sqlite
*.sqlite3

# Test dosyaları
test-*.js
test-*.html
test-*.py
*-test.js
*-test.html
comprehensive-test.js
test-results.html

# Migration dosyaları (bir kere kullanıldı)
migrate-*.js
migrate-*.html
migrate-*.py

# Setup scriptleri (kurulum sonrası gereksiz)
setup*.sh
deploy.sh
cleanup-*.sh

# Debug dosyaları
check-*.html
verify-*.html

# Node modules
node_modules/
backend/node_modules/

# Environment variables
.env
.env.local
.env.production
*.env

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Eski klasörler
api/
database/
backend/backend/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary files
*.tmp
*.temp
*.bak
*.backup

# Build files
dist/
build/
.next/
*.min.js
*.min.css

# Package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# Prisma
backend/prisma/migrations/

# Secrets
*.pem
*.key
*.cert

