# ============================================
# Frontend Environment Variables
# ============================================

# Supabase (Public - Safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API (if using Express backend)
NEXT_PUBLIC_API_URL=http://localhost:8006

# ============================================
# NOTES:
# ============================================
# 1. NEXT_PUBLIC_ prefix makes variables available in browser
# 2. These keys are safe to expose (anon key is public)
# 3. NEVER put SUPABASE_SERVICE_ROLE_KEY in frontend
# 4. For Next.js, create .env.local file
# 5. For Vite, use VITE_ prefix instead of NEXT_PUBLIC_
