<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eğitim Modülleri - SEBS Global</title>
    <meta name='description' content="SEBS Global'nin kapsamlı eğitim modülleri. Siber güvenlik, bulut bilişim, veri bilimleri ve daha fazla alanda uzmanlaşın.">
    <meta name="keywords" content="eğitim modülleri, siber güvenlik, bulut bilişim, veri bilimleri, teknoloji, iş dünyası, kişisel gelişim, SEBS Global">
    <meta name="author" content="SEBS Global">
    <meta name="robots" content="index, follow">
    <meta name="language" content="Turkish">
    <meta name="revisit-after" content="7 days">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://cyberguard-academy.com/modules.html">
    <meta property="og:title" content="Eğitim Modülleri - SEBS Global">
    <meta property="og:description" content="SEBS Global'nin kapsamlı eğitim modülleri. Siber güvenlik, bulut bilişim, veri bilimleri ve daha fazla alanda uzmanlaşın.">
    <meta property="og:image" content="https://cyberguard-academy.com/og-modules.jpg">
    <meta property="og:site_name" content="SEBS Global">
    <meta property="og:locale" content="tr_TR">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="Eğitim Modülleri - SEBS Global">
    <meta name="twitter:description" content="SEBS Global'nin kapsamlı eğitim modülleri. Siber güvenlik, bulut bilişim, veri bilimleri ve daha fazla alanda uzmanlaşın.">
    <meta name="twitter:image" content="https://cyberguard-academy.com/og-modules.jpg">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://cyberguard-academy.com/modules.html">
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/SEBS.png">
    <link rel="apple-touch-icon" href="/images/SEBS.png">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    
    <!-- Styles -->
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/modules.css">
    <link rel="stylesheet" href="/css/styles-level-groups.css">
    
    <style>
        /* Minimal inline styles - only for critical loading overlay */
        /* Main styles are in /css/styles.css and /css/modules.css */

        /* Dark Mode Toggle */
        .dark-mode-toggle {
            background: none;
            border: 2px solid var(--text-secondary);
            border-radius: 12px;
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            color: var(--text-primary);
            margin-left: 1rem;
        }

        .dark-mode-toggle:hover {
            background: var(--bg-secondary);
            border-color: var(--text-primary);
        }

        [data-theme="dark"] .dark-mode-toggle {
            border-color: #1e40af;
            color: #60a5fa;
        }

        [data-theme="dark"] .dark-mode-toggle:hover {
            background: #1e3a8a;
            border-color: #60a5fa;
        }

        /* Navigation */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            background: var(--navbar-bg);
            backdrop-filter: blur(20px);
            padding: 1rem 0;
            z-index: 1000;
            border-bottom: 1px solid var(--border-color);
            transition: all 0.3s ease;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.05);
        }

        [data-theme="dark"] .navbar {
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 0.9rem !important;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .nav-logo-img {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            object-fit: cover;
        }

        .nav-logo .sebs {
            color: var(--text-primary);
        }

        .nav-logo .global {
            background: var(--gradient-purple);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        [data-theme="dark"] .nav-logo .global {
            background: linear-gradient(135deg, #3b82f6 0%, #1e40af 50%, #1e3a8a 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 2.5rem;
            margin: 0;
            padding: 0;
        }

        .nav-menu li {
            margin: 0;
        }

        .nav-link {
            text-decoration: none;
            color: var(--text-secondary);
            font-weight: 500;
            font-size: 0.813rem !important;
            transition: all 0.3s ease;
            position: relative;
            padding: 0.5rem 0;
        }

        .nav-link:hover {
            color: #3182ce;
        }

        [data-theme="dark"] .nav-link:hover {
            color: #60a5fa;
        }

        .nav-link.active {
            color: #3182ce;
            font-weight: 600;
        }

        [data-theme="dark"] .nav-link.active {
            color: #3b82f6;
        }

        .nav-buttons {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .btn-login {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            background: white;
            color: #3182ce;
            border: 2px solid #3182ce;
        }

        .btn-login:hover {
            background: #3182ce;
            color: white;
            transform: translateY(-1px);
        }

        .btn-signup {
            padding: 0.75rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 70%, #a855f7 100%);
            color: white;
            border: none;
        }

        .btn-signup:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

        .user-profile:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
        }

        .user-name {
            color: var(--text-primary);
            font-weight: 500;
            font-size: 0.9rem;
        }

        .btn-logout {
            padding: 0.5rem 1rem;
            border-radius: 8px;
            background: #e53e3e;
            color: white;
            border: none;
            font-weight: 500;
            font-size: 0.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-logout:hover {
            background: #c53030;
            transform: translateY(-1px);
        }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 4px;
            background: none;
            border: none;
            padding: 0.5rem;
        }

        .hamburger span {
            width: 25px;
            height: 3px;
            background: #4a5568;
            transition: all 0.3s ease;
            border-radius: 2px;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .nav-menu {
                display: none;
            }

            .hamburger {
                display: flex;
            }

            .nav-buttons {
                gap: 0.5rem;
            }

            .btn-login, .btn-signup {
                padding: 0.5rem 1rem;
                font-size: 0.8rem;
            }
        }

        /* Loading Animation */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: var(--gradient-purple);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            transition: opacity 0.5s ease-out, visibility 0.5s ease-out;
        }

        [data-theme="dark"] .loading-overlay {
            background: linear-gradient(135deg, #1e3a8a 0%, #1e40af 50%, #1e3a8a 100%);
        }

        .loading-overlay.hidden {
            opacity: 0;
            visibility: hidden;
        }

        .loading-container {
            text-align: center;
            color: white;
        }

        .loading-logo {
            width: 80px;
            height: 80px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 30px;
            font-size: 2rem;
            animation: pulse 2s ease-in-out infinite;
        }

        .loading-spinner {
            width: 60px;
            height: 60px;
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-top: 4px solid white;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 20px;
        }

        .loading-text {
            font-family: 'Space Grotesk', sans-serif;
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 10px;
            animation: fadeInOut 2s ease-in-out infinite;
        }

        .loading-subtext {
            font-size: 1rem;
            opacity: 0.8;
            animation: fadeInOut 2s ease-in-out infinite 0.5s;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        @keyframes fadeInOut {
            0%, 100% { opacity: 0.6; }
            50% { opacity: 1; }
        }

        :root {
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --primary-gradient-soft: linear-gradient(135deg, #667eea 0%, #764ba2 85%, #a855f7 100%);
            --secondary-gradient: linear-gradient(135deg, #2d3748 0%, #4a5568 100%);
            --accent-gradient: linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%);
            --dark-gradient: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            --glass-bg: rgba(255, 255, 255, 0.1);
            --glass-border: rgba(255, 255, 255, 0.2);
            --text-primary: #1e293b;
            --text-secondary: #64748b;
            --text-light: #94a3b8;
            --text-color: #1e293b;
            --primary-color: #667eea;
            --bg-primary: #f8fafc;
            --bg-secondary: #ffffff;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        }

        /* Category Tabs Styles */
        .category-tabs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 50px;
            flex-wrap: wrap;
        }

        .tab-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(102, 126, 234, 0.2);
            border-radius: 15px;
            padding: 15px 25px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-color);
            backdrop-filter: blur(10px);
            min-width: 180px;
            justify-content: center;
        }

        .tab-btn:hover {
            background: rgba(102, 126, 234, 0.1);
            border-color: rgba(102, 126, 234, 0.4);
            transform: translateY(-2px);
        }

        .tab-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: transparent;
            color: white;
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.3);
        }

        .tab-btn i {
            font-size: 1.2rem;
        }

        .module-category-section {
            animation: fadeIn 0.5s ease-in-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .category-title {
            font-size: 2.5rem;
            color: var(--text-color);
            margin-bottom: 40px;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 15px;
        }

        .category-title i {
            color: var(--primary-color);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .category-tabs {
                flex-direction: column;
                align-items: center;
                gap: 15px;
                margin-bottom: 30px;
            }

            .tab-btn {
                width: 100%;
                max-width: 300px;
                min-width: auto;
                padding: 12px 20px;
                font-size: 0.9rem;
            }

            .category-title {
                font-size: 2rem;
                flex-direction: column;
                gap: 10px;
            }
        }
    </style>
</head>
<body>
    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-container">
            <div class="loading-logo">
                <img src="/images/SEBS.png" alt="SEBS Logo" style="width: 60px; height: 60px; object-fit: contain;"/>
            </div>
            <div class="loading-spinner"></div>
            <div class="loading-text">SEBS Global</div>
            <div class="loading-subtext">Yükleniyor...</div>
            </div>
    </div>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="index.html" class="nav-logo">
                <img src="/images/SEBS.png" alt="SEBS Logo" class="nav-logo-img"/>
                <span class="sebs">SEBS</span>
                <span class="global">Global</span>
            </a>
            <ul class="nav-menu" id="navMenu" role="menubar">
                <li class="nav-item" role="none">
                    <a href="index.html" class="nav-link" data-page="index" role="menuitem">
                        <i class="fas fa-home"></i> Ana Sayfa
                    </a>
                </li>
                <li class="nav-item" role="none">
                    <a href="modules.html" class="nav-link" data-page="modules" role="menuitem">
                        <i class="fas fa-book"></i> Eğitim Modülleri
                    </a>
                </li>
                <li class="nav-item" role="none">
                    <a href="simulations.html" class="nav-link" data-page="simulations" role="menuitem">
                        <i class="fas fa-flask"></i> Simülasyonlar
                    </a>
                </li>
                <li class="nav-item" role="none">
                    <a href="about.html" class="nav-link" data-page="about" role="menuitem">
                        <i class="fas fa-info-circle"></i> Hakkımızda
                    </a>
                </li>
                <li class="nav-item" role="none">
                    <a href="contact.html" class="nav-link" data-page="contact" role="menuitem">
                        <i class="fas fa-envelope"></i> İletişim
                    </a>
                </li>
            </ul>
            <div class="nav-buttons">
                <button class="dark-mode-toggle" id="darkModeToggle" aria-label="Gece Modu">
                    <i class="fas fa-moon" id="darkModeIcon"></i>
                </button>
                <div id="userProfile" class="user-profile" style="display: none;">
                    <div class="user-avatar" id="userAvatar">D</div>
                    <span class="user-name" id="userName">Demo Kullanıcı</span>
                </div>
                <a href="login.html" class="btn-login" id="loginBtn">Giriş Yap</a>
                <a href="signup.html" class="btn-signup" id="signupBtn">Üye Ol</a>
                <a href="dashboard.html" class="btn-dashboard" id="dashboardBtn" style="display: none;">
                    <i class="fas fa-tachometer-alt"></i> Panel
                </a>
                <a href="#" onclick="logout()" class="btn-logout" id="logoutBtn" style="display: none;">
                    <i class="fas fa-sign-out-alt"></i> Çıkış Yap
                </a>
            </div>
            <button class="hamburger" id="hamburgerBtn" aria-label="Menüyü aç/kapat" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="modules-hero">
        <div class="container">
            <div class="hero-content">
                <h1>Eğitim Modülleri</h1>
                <p>Farklı alanlarda uzmanlaşmak için kapsamlı eğitim programlarımızı keşfedin</p>
            </div>
        </div>
    </section>

    <!-- Module Categories -->
    <section class="module-categories">
        <div class="container">
            <div class="category-tabs">
                <button class="tab-btn active" data-category="cybersecurity">
                    <i class="fas fa-shield-alt"></i>
                    <span>Siber Güvenlik</span>
                </button>
                <button class="tab-btn" data-category="cloud">
                    <i class="fas fa-cloud"></i>
                    <span>Bulut Bilişim</span>
                </button>
                <button class="tab-btn" data-category="data-science">
                    <i class="fas fa-database"></i>
                    <span>Veri Bilimleri</span>
                </button>
                <button class="tab-btn" data-category="technology">
                    <i class="fas fa-code"></i>
                    <span>Teknoloji</span>
                </button>
                <button class="tab-btn" data-category="business">
                    <i class="fas fa-briefcase"></i>
                    <span>İş Dünyası</span>
                </button>
                <button class="tab-btn" data-category="personal">
                    <i class="fas fa-user-graduate"></i>
                    <span>Kişisel Gelişim</span>
                </button>
            </div>
        </div>
    </section>

    <!-- Modules Grid -->
    <section class="modules-detailed">
        <div class="container">
            <!-- Siber Güvenlik Modülleri -->
            <div class="module-category-section" id="cybersecurity-modules">
                <h2 class="category-title">
                    <i class="fas fa-shield-alt"></i>
                    Siber Güvenlik Modülleri
                </h2>
                
                <!-- Level-based Module Groups -->
                <div class="level-groups-container">
                    <!-- BAŞLANGIÇ SEVİYESİ -->
                    <div class="level-group-card" data-level="beginner" data-category="cybersecurity">
                        <div class="level-group-header">
                            <div class="level-group-icon">
                                <i class="fas fa-seedling"></i>
                            </div>
                            <div class="level-group-info">
                                <h2 class="level-group-title">Başlangıç Seviyesi</h2>
                                <p class="level-group-description">Siber güvenlik dünyasına ilk adımınızı atın. Temel kavramlar ve prensipleri öğrenin.</p>
                            </div>
                        </div>
                        <div class="level-group-content">
                            <div class="level-group-modules">
                                <h3>İçerik:</h3>
                                <ul class="module-list">
                                    <li><i class="fas fa-check-circle"></i> Siber Güvenliğe Giriş</li>
                                    <li><i class="fas fa-check-circle"></i> Temel Network Eğitimi</li>
                                    <li><i class="fas fa-check-circle"></i> İşletim Sistemleri Güvenliği (Temel)</li>
                                    <li><i class="fas fa-check-circle"></i> Temel Kriptografi</li>
                                    <li><i class="fas fa-check-circle"></i> Sosyal Mühendisliğe Giriş</li>
                                </ul>
                            </div>
                            <div class="level-group-features">
                                <div class="feature-item">
                                    <i class="fas fa-book"></i>
                                    <span>5 Modül</span>
                                </div>
                                <div class="feature-item">
                                    <i class="fas fa-clock"></i>
                                    <span>200+ Saat</span>
                                </div>
                                <div class="feature-item">
                                    <i class="fas fa-users"></i>
                                    <span>500+ Öğrenci</span>
                                </div>
                            </div>
                        </div>
                        <div class="level-group-footer">
                            <div class="level-group-price">
                                <span class="price-label">Fiyat:</span>
                                <span class="price-amount">₺149</span>
                            </div>
                            <a href="pricing.html?category=cybersecurity&level=beginner" class="btn-purchase">
                                <i class="fas fa-shopping-cart"></i>
                                Satın Al
                            </a>
                        </div>
                    </div>

                    <!-- ORTA SEVİYE -->
                    <div class="level-group-card" data-level="intermediate" data-category="cybersecurity">
                        <div class="level-group-header">
                            <div class="level-group-icon">
                                <i class="fas fa-chart-line"></i>
                            </div>
                            <div class="level-group-info">
                                <h2 class="level-group-title">Orta Seviye</h2>
                                <p class="level-group-description">İleri teknikleri öğrenin ve pratik uygulamalarla becerilerinizi geliştirin.</p>
                            </div>
                        </div>
                        <div class="level-group-content">
                            <div class="level-group-modules">
                                <h3>İçerik:</h3>
                                <ul class="module-list">
                                    <li><i class="fas fa-check-circle"></i> Network Güvenliği</li>
                                    <li><i class="fas fa-check-circle"></i> Web Uygulama Güvenliği</li>
                                    <li><i class="fas fa-check-circle"></i> Malware Analizi (Orta Seviye)</li>
                                    <li><i class="fas fa-check-circle"></i> SOC (Security Operations Center) Eğitimi</li>
                                    <li><i class="fas fa-check-circle"></i> İşletim Sistemi Güvenliği (İleri Temel)</li>
                                    <li><i class="fas fa-check-circle"></i> Temel Cloud Security</li>
                                </ul>
                            </div>
                            <div class="level-group-features">
                                <div class="feature-item">
                                    <i class="fas fa-book"></i>
                                    <span>6 Modül</span>
                                </div>
                                <div class="feature-item">
                                    <i class="fas fa-clock"></i>
                                    <span>300+ Saat</span>
                                </div>
                                <div class="feature-item">
                                    <i class="fas fa-users"></i>
                                    <span>300+ Öğrenci</span>
                                </div>
                            </div>
