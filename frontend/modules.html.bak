    <!-- modules.js removed - not needed -->
    <script>
        // Loading Animation
        window.addEventListener('load', function() {
            const loadingOverlay = document.getElementById('loadingOverlay');
            setTimeout(() => {
                loadingOverlay.classList.add('hidden');
                setTimeout(() => {
                    loadingOverlay.style.display = 'none';
                }, 500);
            }, 1500); // 1.5 saniye loading göster
        });

        document.addEventListener('DOMContentLoaded', () => {
            // Get URL parameters
            const urlParams = new URLSearchParams(window.location.search);
            const category = urlParams.get('category');
            
            // Category tabs functionality
            const categoryTabs = document.querySelectorAll('.tab-btn');
            const moduleCategories = document.querySelectorAll('.module-category-section');

            // Function to switch category
            function switchCategory(targetCategory) {
                // Remove active class from all tabs
                categoryTabs.forEach(t => t.classList.remove('active'));
                
                // Hide all module categories
                moduleCategories.forEach(category => {
                    category.style.display = 'none';
                });
                
                // Show selected category
                const selectedCategory = document.getElementById(targetCategory + '-modules');
                if (selectedCategory) {
                    selectedCategory.style.display = 'block';
                }
                
                // Find and activate the corresponding tab
                const activeTab = document.querySelector(`[data-category="${targetCategory}"]`);
                if (activeTab) {
                    activeTab.classList.add('active');
                }
            }

            // Set initial category based on URL parameter
            if (category) {
                switchCategory(category);
            }

            // Add click listeners to tabs
            categoryTabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    const tabCategory = tab.getAttribute('data-category');
                    switchCategory(tabCategory);
                    
                    // Update URL without page reload
                    const newUrl = new URL(window.location);
                    newUrl.searchParams.set('category', tabCategory);
                    window.history.pushState({}, '', newUrl);
                });
            });
        });

        // Access Control - Async version with token verification
        async function checkAccess() {
            const token = localStorage.getItem('authToken');
            const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
            
            // If no token or not logged in, show access denied
            if (!token || !isLoggedIn) {
                showAccessDenied();
                return false;
            }
            
            // Verify token with API
            try {
                const response = await fetch('http://localhost:8006/api/users/me', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });
                
                if (!response.ok) {
                    // Token invalid, clear storage and show access denied
                    localStorage.removeItem('authToken');
                    localStorage.removeItem('isLoggedIn');
                    localStorage.removeItem('isVerified');
                    localStorage.removeItem('userEmail');
                    localStorage.removeItem('userRole');
                    showAccessDenied();
                    return false;
                }
                
                const result = await response.json();
                if (result.success && result.data) {
                    // Token is valid, user is authenticated
                    // Update localStorage with verified status
                    localStorage.setItem('isVerified', result.data.isVerified ? 'true' : 'false');
                    return true;
                } else {
                    showAccessDenied();
                    return false;
                }
            } catch (error) {
                console.error('Error verifying token:', error);
                // On error, allow access if token exists (offline mode)
                // But show warning
                if (token && isLoggedIn) {
                    return true;
                }
                showAccessDenied();
                return false;
            }
        }
        
        function showAccessDenied() {
                const mainContent = document.querySelector('.main-content');
                if (mainContent) {
                    mainContent.innerHTML = `
                        <div style="text-align: center; padding: 60px 20px;">
                            <div style="width: 100px; height: 100px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 30px; font-size: 2.5rem; color: white;">
                                <i class="fas fa-lock"></i>
                            </div>
                            <h2 style="font-family: 'Space Grotesk', sans-serif; font-size: 2.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 20px;">
                                Erişim Gerekli
                            </h2>
                            <p style="color: var(--text-secondary); font-size: 1.2rem; margin-bottom: 30px; max-width: 600px; margin-left: auto; margin-right: auto;">
                                Eğitim modüllerine erişim için üye olmanız ve e-posta adresinizi doğrulamanız gerekmektedir.
                            </p>
                            <div style="display: flex; gap: 20px; justify-content: center; flex-wrap: wrap;">
                                <a href="signup.html" style="background: linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%); color: white; padding: 15px 30px; border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease;">
                                    Üye Ol
                                </a>
                                <a href="login.html" style="background: transparent; color: var(--primary-color); padding: 15px 30px; border: 2px solid var(--primary-color); border-radius: 25px; text-decoration: none; font-weight: 600; transition: all 0.3s ease;">
                                    Giriş Yap
                                </a>
                            </div>
                        </div>
                    `;
                }
                
                // Hide navigation
                const nav = document.querySelector('.navbar');
                if (nav) {
                    nav.style.display = 'none';
                }
        }

        // Check access on page load
        // Check authentication status
        function checkAuthStatus() {
            const isLoggedIn = localStorage.getItem('isLoggedIn');
            const isVerified = localStorage.getItem('isVerified');
            const userData = JSON.parse(localStorage.getItem('userData') || '{}');
            
            // Find the modules and simulations links
            const modulesLink = document.querySelector('a[href="modules.html"]');
            const simulationsLink = document.querySelector('a[href="simulations.html"]');
            
            if (isLoggedIn === 'true' && isVerified === 'true') {
                // User is logged in
                document.getElementById('loginBtn').style.display = 'none';
                document.getElementById('signupBtn').style.display = 'none';
                document.getElementById('userProfile').style.display = 'flex';
                document.getElementById('logoutBtn').style.display = 'block';
                
                // Show modules link for logged in users
                if (modulesLink) {
                    modulesLink.parentElement.style.display = 'block';
                }
                
                // Show simulations link for logged in users
                if (simulationsLink) {
                    simulationsLink.parentElement.style.display = 'block';
                }
                
                // Update user info
                const userName = userData.name || userData.firstName || 'Kullanıcı';
                document.getElementById('userName').textContent = userName;
                document.getElementById('userAvatar').textContent = userName.charAt(0).toUpperCase();
                
                // Make user profile clickable to go to dashboard
                document.getElementById('userProfile').onclick = function() {
                    window.location.href = 'dashboard.html';
                };
            } else {
                // User is not logged in
                document.getElementById('loginBtn').style.display = 'block';
                document.getElementById('signupBtn').style.display = 'block';
                document.getElementById('userProfile').style.display = 'none';
                document.getElementById('logoutBtn').style.display = 'none';
                
                // Hide modules link for non-logged in users
                if (modulesLink) {
                    modulesLink.parentElement.style.display = 'none';
                }
                
                // Hide simulations link for non-logged in users
                if (simulationsLink) {
                    simulationsLink.parentElement.style.display = 'none';
                }
            }
        }

        // Logout function
        function logout() {
            if (confirm('Çıkış yapmak istediğinizden emin misiniz?')) {
                localStorage.removeItem('isLoggedIn');
                localStorage.removeItem('isVerified');
                localStorage.removeItem('userData');
                localStorage.removeItem('userEmail');
                window.location.href = 'index.html';
            }
        }

        // Update logo based on theme
        function updateLogo() {
            const navLogoImg = document.querySelector('.nav-logo-img');
            const html = document.documentElement;
            const currentTheme = html.getAttribute('data-theme') || 'light';
            
            if (navLogoImg) {
                if (currentTheme === 'dark') {
                    navLogoImg.src = 'SEBS.png';
                } else {
                    navLogoImg.src = 'SEBS.png';
                }
            }
        }

        // Dark Mode Toggle
        function initDarkMode() {
            const darkModeToggle = document.getElementById('darkModeToggle');
            const darkModeIcon = document.getElementById('darkModeIcon');
            const html = document.documentElement;
            
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                html.setAttribute('data-theme', 'dark');
                if (darkModeIcon) darkModeIcon.className = 'fas fa-sun';
            }
            
            // Update logo on page load
            updateLogo();
            
            if (darkModeToggle) {
                darkModeToggle.addEventListener('click', function() {
                    const currentTheme = html.getAttribute('data-theme');
                    if (currentTheme === 'dark') {
                        html.setAttribute('data-theme', 'light');
                        localStorage.setItem('theme', 'light');
                        if (darkModeIcon) darkModeIcon.className = 'fas fa-moon';
                    } else {
                        html.setAttribute('data-theme', 'dark');
                        localStorage.setItem('theme', 'dark');
                        if (darkModeIcon) darkModeIcon.className = 'fas fa-sun';
                    }
                    // Update logo when theme changes
                    updateLogo();
                });
            }
        }

        document.addEventListener('DOMContentLoaded', async function() {
            const hasAccess = await checkAccess();
            if (hasAccess) {
            checkAuthStatus();
            initDarkMode();
            
            // Add logout button event listener
            const logoutBtn = document.getElementById('logoutBtn');
            if (logoutBtn) logoutBtn.onclick = logout;
            }
        });
    </script>
    <!-- Navigation Script -->
    <script src="js/navigation.js?v=2.0"></script>
    <!-- Access Control -->
    <script src="utils/access-control.js"></script>
    
    <script>
        // Get user access level from database
        async function getUserAccessLevel() {
            const token = localStorage.getItem('authToken');
            if (!token) {
                return 'beginner';
            }

            try {
                const response = await fetch('http://localhost:8006/api/users/me', {
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                if (response.ok) {
                    const result = await response.json();
                    if (result.success && result.data) {
                        return result.data.accessLevel || 'beginner';
                    }
                }
            } catch (error) {
                console.error('Error fetching access level:', error);
            }
            
            return 'beginner';
        }

        // Map level badge text to level
        function getLevelFromBadge(badgeElement) {
            if (!badgeElement) return 'beginner';
            const text = badgeElement.textContent.trim();
            if (text.includes('Orta')) return 'intermediate';
            if (text.includes('İleri')) return 'advanced';
            return 'beginner';
        }

        // Filter and display modules based on user's access level
        async function filterModulesByAccessLevel() {
            const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
            const userAccessLevel = await getUserAccessLevel();
            
            console.log('🔵 Filtering modules - User access level:', userAccessLevel, 'Logged in:', isLoggedIn);
            
            // Get all module cards
            const moduleCards = document.querySelectorAll('.module-card-detailed');
            let visibleCount = 0;
            
            moduleCards.forEach(card => {
                const levelBadge = card.querySelector('.level-badge');
                const moduleLevel = getLevelFromBadge(levelBadge);
                
                // If user is not logged in, hide all modules
                if (!isLoggedIn) {
                    card.style.display = 'none';
                    return;
                }
                
                // Show only modules that match user's access level
                if (moduleLevel === userAccessLevel) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });
            
            // Update level group cards to show purchase status
            const levelGroupCards = document.querySelectorAll('.level-group-card');
            levelGroupCards.forEach(groupCard => {
                const groupLevel = groupCard.dataset.level;
                const purchaseButton = groupCard.querySelector('.btn-purchase');
                const priceSection = groupCard.querySelector('.level-group-price');
                
                if (groupLevel === userAccessLevel && isLoggedIn) {
                    // User has purchased this level
                    if (purchaseButton) {
                        purchaseButton.innerHTML = '<i class="fas fa-check"></i> Satın Alındı';
                        purchaseButton.style.background = 'linear-gradient(135deg, #22c55e 0%, #16a34a 100%)';
                        purchaseButton.style.cursor = 'default';
                        purchaseButton.onclick = (e) => {
                            e.preventDefault();
                            return false;
                        };
                    }
                    if (priceSection) {
                        priceSection.innerHTML = '<span class="price-label" style="color: #22c55e;"><i class="fas fa-check-circle"></i> Bu pakete sahipsiniz</span>';
                    }
                } else if (isLoggedIn) {
                    // User hasn't purchased this level
                    if (purchaseButton) {
                        purchaseButton.innerHTML = '<i class="fas fa-shopping-cart"></i> Satın Al';
                        purchaseButton.style.background = '';
                        purchaseButton.style.cursor = 'pointer';
                    }
                }
            });
            
            // Show message if no modules are visible
            if (isLoggedIn && visibleCount === 0) {
                const modulesSection = document.querySelector('.module-category-section');
                if (modulesSection) {
                    let noModulesMessage = modulesSection.querySelector('.no-modules-message');
                    if (!noModulesMessage) {
                        noModulesMessage = document.createElement('div');
                        noModulesMessage.className = 'no-modules-message';
                        noModulesMessage.style.cssText = `
                            text-align: center;
                            padding: 3rem 2rem;
                            background: var(--bg-secondary);
                            border-radius: 16px;
                            margin: 2rem 0;
                        `;
                        noModulesMessage.innerHTML = `
                            <div style="font-size: 4rem; color: var(--text-secondary); margin-bottom: 1rem;">
                                <i class="fas fa-lock"></i>
                            </div>
                            <h3 style="font-family: 'Space Grotesk', sans-serif; font-size: 1.5rem; color: var(--text-primary); margin-bottom: 1rem;">
                                Henüz Bu Seviyede Modülünüz Yok
                            </h3>
                            <p style="color: var(--text-secondary); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
                                ${userAccessLevel === 'beginner' ? 'Temel' : userAccessLevel === 'intermediate' ? 'Orta' : 'İleri'} seviye paketini satın alarak bu seviyedeki modüllere erişebilirsiniz.
                            </p>
                            <a href="pricing.html?category=cybersecurity&level=${userAccessLevel}" style="
                                display: inline-block;
                                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
                                color: white;
                                padding: 12px 32px;
                                border-radius: 12px;
                                text-decoration: none;
                                font-weight: 600;
                                transition: all 0.3s ease;
                            " onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 10px 20px rgba(102, 126, 234, 0.3)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'">
                                <i class="fas fa-shopping-cart"></i> Paketleri Görüntüle
                            </a>
                        `;
                        modulesSection.appendChild(noModulesMessage);
                    }
                }
            } else {
                // Remove message if modules are visible
                const noModulesMessage = document.querySelector('.no-modules-message');
                if (noModulesMessage) {
                    noModulesMessage.remove();
                }
            }
        }

        // Module access control
        document.addEventListener('DOMContentLoaded', async () => {
            // Wait for AccessControl to be available
            let retries = 0;
            while (!window.AccessControl && retries < 10) {
                await new Promise(resolve => setTimeout(resolve, 100));
                retries++;
            }
            
            // Filter modules based on access level
            await filterModulesByAccessLevel();
            
            // Add access level data attributes to module links
            const moduleLinks = document.querySelectorAll('.btn-module');
            moduleLinks.forEach(link => {
                const card = link.closest('.module-card-detailed');
                if (card) {
                    const levelBadge = card.querySelector('.level-badge');
                    if (levelBadge) {
                        let level = 'beginner';
                        if (levelBadge.textContent.includes('Orta')) {
                            level = 'intermediate';
                        } else if (levelBadge.textContent.includes('İleri')) {
                            level = 'advanced';
                        }
                        link.dataset.moduleLevel = level;
                        
                        // Get category from card
                        const category = card.dataset.category || 'cybersecurity';
                        link.dataset.moduleCategory = category;
                    }
                }
            });

            // Check access on module link click
            moduleLinks.forEach(link => {
                link.addEventListener('click', async (e) => {
                    e.preventDefault(); // Always prevent default first
                    e.stopPropagation();
                    
                    console.log('🔵 Module button clicked');
                    
                    // Check if user is logged in
                    const isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
                    console.log('🔵 Is logged in:', isLoggedIn);
                    
                    if (!isLoggedIn) {
                        if (confirm('Bu modüle erişim için giriş yapmanız gerekiyor. Giriş sayfasına yönlendirileceksiniz.')) {
                            window.location.href = 'login.html?redirect=' + encodeURIComponent(window.location.pathname);
                        }
                        return false;
                    }
                    
                    const moduleLevel = link.dataset.moduleLevel || 'beginner';
                    const card = link.closest('.module-card-detailed');
                    const category = card?.dataset.category || 'cybersecurity';
                    
                    console.log('🔵 Module level:', moduleLevel, 'Category:', category);
                    console.log('🔵 AccessControl available:', !!window.AccessControl);
                    
                    // If AccessControl is not available, redirect to pricing
                    if (!window.AccessControl) {
                        console.warn('⚠️ AccessControl not available, redirecting to pricing');
                        window.location.href = `pricing.html?category=${category}&level=${moduleLevel}`;
                        return false;
                    }
                    
                    try {
                        const accessCheck = await window.AccessControl.checkModuleAccess(moduleLevel, category);
                        console.log('🔵 Access check result:', accessCheck);
                        
                        if (!accessCheck.hasAccess) {
                            // Redirect to pricing page immediately (no confirm)
                            console.log('🔵 No access, redirecting to pricing page');
                            window.location.href = `pricing.html?category=${category}&level=${moduleLevel}`;
                            return false;
                        }
                    } catch (error) {
                        console.error('❌ Access check error:', error);
                        // On error, redirect to pricing page
                        window.location.href = `pricing.html?category=${category}&level=${moduleLevel}`;
                        return false;
                    }
                    
                    // If access is granted, proceed to module
                    const href = link.getAttribute('href');
                    if (href) {
                        console.log('✅ Access granted, proceeding to module:', href);
                        window.location.href = href;
                    }
                });
            });
        });

        // Listen for storage changes (when user purchases a package)
        window.addEventListener('storage', async (e) => {
            if (e.key === 'authToken') {
                await filterModulesByAccessLevel();
            }
        });

        // Also check when page becomes visible (in case purchase happened in another tab)
        document.addEventListener('visibilitychange', async () => {
            if (!document.hidden) {
                await filterModulesByAccessLevel();
            }
        });
    </script>
</body>
</html>